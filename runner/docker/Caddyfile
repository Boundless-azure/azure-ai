# Runner Caddy 配置
# 上游地址通过环境变量 RUNNER_UPSTREAM 注入：
#   Docker 模式： RUNNER_UPSTREAM=runner-app:4310
#   宿主机模式： RUNNER_UPSTREAM=host.docker.internal:4310

{
  # 开启 Caddy admin API
  admin 0.0.0.0:2019
}

# 默认 HTTP 入口：接收来自 frpc 穿透的外部流量
:80 {
  reverse_proxy {env.RUNNER_UPSTREAM} {
    header_up Host {host}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Real-IP {remote_host}
  }
}
